# Leave empty during Vite dev to use the `/api` proxy to http://localhost:8787 (see vite.config.ts).
# Required for production / mobile builds — set your deployed API origin (no trailing slash).
# VITE_API_URL=https://api.your-domain.example
VITE_API_PROXY=http://localhost:8787
BACKEND_PORT=8787

# Shown in Account Settings → Diagnostics (e.g. pilot-2026-05-10).
VITE_APP_VERSION=
