PORT=8787
NODE_ENV=development
JWT_SECRET=change-me-use-a-long-random-string-in-production
# Deployed environments: explicit HTTPS browser origins (web app + ops dashboard).
# FRONTEND_ORIGINS=https://ekasi-pay-web.onrender.com,https://ekasi-ops-dashboard.onrender.com
# Optional explicit ops origin (also merged into CORS allowlist):
# OPS_DASHBOARD_ORIGIN=https://ekasi-ops-dashboard.onrender.com
FRONTEND_ORIGIN=http://localhost:5173

DATABASE_PATH=./data/ekasi-pay.db
# Required whenever NODE_ENV is not development/test. SQLite is local-only.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# Postgres SSL: set PG_SSL_REJECT_UNAUTHORIZED=false only if your host uses a private CA.
# PG_SSL_REJECT_UNAUTHORIZED=false
# Postgres integration tests (opt-in): PG_INTEGRATION_TESTS=1 npm run test:integration
# Dev wallet credit: CREDIT_AMOUNT=1000000 CREDIT_PHONE=0821234567 npm run credit-wallet

# Access JWT lifetime (seconds). Refresh window is separate.
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=604800
REFRESH_ABSOLUTE_TTL_SEC=2592000
BCRYPT_ROUNDS=12
# Required and distinct from all JWT/pepper secrets in deployed environments.
# REFRESH_TOKEN_PEPPER=use-a-separate-32-plus-character-secret

# PIN_RESET_PEPPER=use-another-separate-32-plus-character-secret
# OPS_JWT_SECRET=use-another-separate-32-plus-character-secret
# OPS_REFRESH_TOKEN_PEPPER=use-a-distinct-32-plus-character-secret
# Ten-minute maximum operator access token.
OPS_TOKEN_TTL_SEC=600
# Enables the temporary JSON refresh-token compatibility path in production.
# Prefer false for browser deployments using secure cookies.
# BEARER_REFRESH_COMPATIBILITY=false
# REFRESH_COOKIE_ENABLED=true
# 32-byte key encoded as 64 hex characters or base64.
# DATA_ENCRYPTION_KEY=
# Optional active version stamped into new ciphertexts (default 1).
# DATA_ENCRYPTION_KEY_VERSION=1
# Previous keys for decrypt-during-rotation: version:key,version:key
# DATA_ENCRYPTION_KEY_PREVIOUS=1:<previous-32-byte-key>

# Brute-force protection: requests per IP per minute to POST /api/login, /api/register, /api/refresh
LOGIN_RATE_LIMIT_PER_MIN=20
# Shared counters across API instances — required outside development/test:
# RATE_LIMIT_REDIS_URL=redis://:password@redis.example:6379/0

# --- Production required ---
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+27...
# SMS_PROVIDER=clickatell
# CLICKATELL_API_KEY=

# Cash Send sends reference and PIN in separate messages (uses SMS_PROVIDER above).
# CASH_SEND_COLLECT_HINT=Withdraw at any KasiPay partner shop (Services > Collect cash).

# Risky / regulated money products fail closed outside local development.
# FINANCIAL_POSTING_ENABLED=false
# LENDING_ENABLED=false
# LENDING_DISBURSEMENT_ENABLED=false
# INSURANCE_ENABLED=false
# STOKVEL_MONEY_MOVEMENT_ENABLED=false
# CASH_SEND_ENABLED=false
# LIVE_UTILITIES_ENABLED=false
# Blind-index pepper for Cash Send / KYC identifier matching (32+ chars).
# Required and distinct from DATA_ENCRYPTION_KEY / JWT / refresh secrets in deployed envs.
# PII_HASH_PEPPER=
# PII_HASH_PEPPER_VERSION=1
# Previous peppers for blind-index rotation: version:pepper,version:pepper
# PII_HASH_PEPPER_PREVIOUS=1:<previous-pepper>

# Utility purchases: mock (dev default), http (vendor webhook), or disabled (production default)
# UTILITY_PROVIDER=mock
# UTILITY_MAX_AMOUNT=500
# UTILITY_VENDOR_WEBHOOK_URL=https://vendor.example.com/utility/purchase
# UTILITY_VENDOR_API_KEY=
# Separate HMAC secret for signed provider callbacks (32+ random characters).
# PROVIDER_CALLBACK_SECRET=

# Phase 7 regulated products are fail-closed. Sandbox also requires complete
# immutable sandbox evidence in product_readiness_evidence.
# PHASE7_SANDBOX_ENABLED=false
# Production requires the global gate, the product-specific gate, and complete
# unexpired production evidence. Do not set these without external sign-off.
# REGULATED_PRODUCTS_PRODUCTION_ENABLED=false
# PRODUCT_STOKVEL_PRODUCTION_ENABLED=false
# PRODUCT_LENDING_PRODUCTION_ENABLED=false
# PRODUCT_MERCHANT_CREDIT_PRODUCTION_ENABLED=false
# PRODUCT_INSURANCE_PRODUCTION_ENABLED=false
# PRODUCT_UTILITIES_PRODUCTION_ENABLED=false

# Load shedding feed source: db (seeded fallback) or http.
# LOAD_SHEDDING_PROVIDER=db
# LOAD_SHEDDING_FEED_URL=https://example.com/load-shedding-feed.json

# Deployed operational readiness markers.
# MONITORING_PROVIDER=sentry
# MONITORING_DSN=https://public-key@sentry.example.com/project
# ALERT_ROUTING_MARKER=configured-in-monitoring-provider
# No fake screening implementation exists; a real integration is required.
# SANCTIONS_PEP_PROVIDER=external
# SANCTIONS_PEP_ENDPOINT=https://screening.example.com/v1/check
# SANCTIONS_PEP_API_KEY=
# Append-only audit events are delivered through the durable audit outbox.
# AUDIT_SINK_PROVIDER=external
# AUDIT_SINK_ENDPOINT=https://audit.example.com/v1/events
# AUDIT_SINK_API_KEY=
# Deliver outbox: npm run audit:deliver
# BACKUP_PROVIDER=neon
BACKUP_RETENTION_DAYS=30
# BACKUP_MAX_AGE_HOURS=26
# RTO_MINUTES=120
# RPO_MINUTES=60
# Explicit evidence markers; values must come from provider configuration/drills.
# BACKUP_ENCRYPTION_MARKER=
# BACKUP_PITR_MARKER=
# BACKUP_VERIFICATION_MARKER=

# Private KYC object storage and malware scanning are mandatory outside dev/test.
# PRIVATE_STORAGE_PROVIDER=external
# PRIVATE_STORAGE_SIGNING_ENDPOINT=https://storage-signing.example.com/v1/sign
# Dev-only local signer: npm run dev:storage-signer → http://127.0.0.1:8791
# PRIVATE_STORAGE_SIGNING_SECRET=
# PRIVATE_STORAGE_ENCRYPTION_KEY_REF=provider-kms-key-id
# MALWARE_SCANNER_PROVIDER=external
# MALWARE_SCANNER_CALLBACK_SECRET=
# Dev-only scanner stub: npm run dev:malware-scan -- --object-key kyc/... --content-type application/pdf
# ALLOW_LEGACY_DB_KYC_UPLOAD=false

# First admin user (run: npm run bootstrap:admin)
# ADMIN_BOOTSTRAP_PHONE=0780000001
# ADMIN_BOOTSTRAP_PIN=4321
# ADMIN_BOOTSTRAP_NAME=Ekasi Admin

# One-time operator bootstrap (never used by normal startup):
# BOOTSTRAP_OPERATOR_USERNAME=
# BOOTSTRAP_OPERATOR_PASSWORD=
# BOOTSTRAP_CONFIRM=CREATE_FIRST_OPERATOR
# npm run bootstrap:operator

# Scheduled backups: npm run backup:db
# BACKUP_DIR=./backups
# SMOKE_PORT=8787

# PostgreSQL release commands:
# npm run migrate:validate
# npm run migrate:status
# npm run migrate:up
# See docs/postgresql-migrations.md for existing-database baseline cutover.
#
# Production readiness gate (fail closed; see docs/phase8-release.md):
# cp evidence/production-readiness.example.json evidence/production-readiness.json
# NODE_ENV=production RELEASE_SHA=<git-sha> DATABASE_URL=postgresql://... npm run production:ready
# Enabling CASH_SEND_ENABLED / LENDING_ENABLED / INSURANCE_ENABLED /
# STOKVEL_MONEY_MOVEMENT_ENABLED requires matching approved productFlags evidence.
