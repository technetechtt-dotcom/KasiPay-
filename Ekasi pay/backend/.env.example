PORT=8787
NODE_ENV=development
JWT_SECRET=change-me-use-a-long-random-string-in-production
FRONTEND_ORIGIN=http://localhost:5173
# Production: comma-separated allowed browser/Capacitor origins (overrides single FRONTEND_ORIGIN when set).
# FRONTEND_ORIGINS=https://app.example.com,https://localhost

DATABASE_PATH=./data/ekasi-pay.db
# Optional Postgres mode (phased dual mode): when set, backend uses Postgres
# for auth + me + wallets + merchants + activity + products + transfers + sales
# + expenses + credit + analytics.
# SQLite remains default when DATABASE_URL is unset.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Access JWT lifetime (seconds). Refresh window is separate.
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=604800
REFRESH_ABSOLUTE_TTL_SEC=2592000
BCRYPT_ROUNDS=12
# Optional; defaults to JWT_SECRET if unset.
# REFRESH_TOKEN_PEPPER=

# Brute-force protection: requests per IP per minute to POST /api/login, /api/register, /api/refresh
LOGIN_RATE_LIMIT_PER_MIN=20

# --- Production required ---
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+27...
# SMS_PROVIDER=clickatell
# CLICKATELL_API_KEY=

# Utility purchases: mock (dev default), http (vendor webhook), or disabled (production default)
# UTILITY_PROVIDER=mock
# UTILITY_MAX_AMOUNT=500
# UTILITY_VENDOR_WEBHOOK_URL=https://vendor.example.com/utility/purchase
# UTILITY_VENDOR_API_KEY=

# Load shedding feed source: db (seeded fallback) or http.
# LOAD_SHEDDING_PROVIDER=db
# LOAD_SHEDDING_FEED_URL=https://example.com/load-shedding-feed.json

# First admin user (run: npm run bootstrap:admin)
# ADMIN_BOOTSTRAP_PHONE=0780000001
# ADMIN_BOOTSTRAP_PIN=4321
# ADMIN_BOOTSTRAP_NAME=Ekasi Admin

# Scheduled backups: npm run backup:db
# BACKUP_DIR=./backups
# SMOKE_PORT=8787
