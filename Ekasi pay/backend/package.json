{
  "name": "ekasi-pay-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "presmoke": "npm run build",
    "smoke": "node scripts/smoke.mjs",
    "seed": "node scripts/seed.mjs",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "backup:db": "node scripts/backup-db.mjs",
    "lint": "eslint . --ext .ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"src/**/*.integration.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.18",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
