{
  "name": "ekasi-pay-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node scripts/ensure-build-deps.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "presmoke": "npm run build",
    "smoke": "node scripts/smoke.mjs",
    "seed": "node scripts/seed.mjs",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "bootstrap:operator": "node scripts/bootstrap-operator.mjs",
    "backup:db": "node scripts/backup-db.mjs",
    "backup:postgres": "node scripts/backup-postgres.mjs",
    "backup:inventory": "node scripts/inventory-objects.mjs",
    "restore:drill": "node scripts/restore-drill.mjs",
    "migrate:up": "node scripts/migrate.mjs up",
    "migrate:status": "node scripts/migrate.mjs status",
    "migrate:validate": "node scripts/migrate.mjs validate",
    "migrate:baseline": "node scripts/migrate.mjs baseline",
    "migrate:expand": "node scripts/migrate.mjs expand",
    "migrate:contract": "node scripts/migrate.mjs contract",
    "money:reconcile": "node scripts/reconcile-money.mjs",
    "ledger:reconcile": "node scripts/reconcile-ledger.mjs",
    "voucher:reconcile": "node scripts/reconcile-vouchers.mjs",
    "voucher:expire": "npm run build && node scripts/expire-vouchers.mjs",
    "phase7:stokvel-inventory": "npm run build && node scripts/inventory-phase7-stokvel.mjs",
    "production:ready": "node scripts/production-readiness.mjs",
    "perf:pilot": "k6 run performance/phase8-pilot.k6.js",
    "perf:recovery": "k6 run performance/phase8-recovery.k6.js",
    "drill": "node scripts/run-failure-drill.mjs",
    "ledger:backfill": "node scripts/backfill-ledger.mjs",
    "lint": "eslint . --ext .ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"src/**/*.integration.test.ts\"",
    "test:postgres": "node --import tsx --test \"src/ledgerPg.integration.test.ts\" \"src/phase6Pg.integration.test.ts\" \"src/phase7Pg.integration.test.ts\" \"src/phase8Pg.integration.test.ts\"",
    "credit-wallet": "node scripts/credit-wallet.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.18",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^9.0.0",
    "pg": "^8.22.0",
    "typescript": "^5.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "tsx": "^4.19.2"
  }
}
