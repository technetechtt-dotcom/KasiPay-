# Ops dashboard — separate deployment from main Ekasi Pay API (default port 8790).
OPS_PORT=8790
NODE_ENV=development

# Sign dashboard session JWTs (>= 32 chars in production).
OPS_JWT_SECRET=change-me-ops-dashboard-jwt-secret-min-32-chars

# Initial super admin bootstrap account.
# On first start, this creates username in ops_admin_users table if missing.
# OPS_SUPER_ADMIN_PASSWORD can be plain text or bcrypt hash.
OPS_SUPER_ADMIN_USERNAME=superadmin
OPS_SUPER_ADMIN_PASSWORD=change-me-super-admin-password
# Backward compatibility fallback (used only when OPS_SUPER_ADMIN_PASSWORD unset):
OPS_DASHBOARD_PASSWORD=change-me-ops-password

# Allowed browser origin for the dashboard UI (production).
OPS_DASHBOARD_ORIGIN=http://localhost:5174

# Read-only data source — same DB as main API, separate process.
# Production: use a Postgres read-only role (Neon → Roles → read-only user).
# DATABASE_URL=postgresql://readonly_user:pass@host/db?sslmode=require
# Postgres SSL: set PG_SSL_REJECT_UNAUTHORIZED=false only if your host uses a private CA.
# PG_SSL_REJECT_UNAUTHORIZED=false
# SQLite (local dev on same machine as API):
DATABASE_PATH=../backend/data/ekasi-pay.db
