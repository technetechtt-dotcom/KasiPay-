# Ops dashboard — static UI that uses the main Ekasi Pay API (ekasi-pay-api).
# No separate ops Node server or OPS_JWT_SECRET.

# Dev: Vite proxies /api → local API (default http://localhost:8787).
# Prod: set API_HOST or VITE_API_URL to the main API origin at build time.
# VITE_API_URL=https://ekasi-pay-api.onrender.com

# Sign in with an admin phone + PIN (same account as More → Admin Tools).
