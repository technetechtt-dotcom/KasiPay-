{
  "name": "ekasi-pay",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "node scripts/write-runtime-config.mjs && npx vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "preview": "npx vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "mobile:build": "node scripts/require-mobile-env.mjs && npm run build && cap sync",
    "mobile:android": "npm run mobile:build && cap open android",
    "mobile:ios": "npm run mobile:build && cap open ios",
    "mobile:verify:ios": "npm run mobile:build && node scripts/verify-ios.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.6.7",
    "@emotion/is-prop-valid": "^1.4.0",
    "@emotion/react": "^11.13.3",
    "framer-motion": "^11.5.4",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "0.522.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "latest",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "jsdom": "^26.1.0",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
